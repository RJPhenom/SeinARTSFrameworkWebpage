---
const DOCS_URL = 'https://docs.seinarts.gg';
const GITHUB_URL = 'https://github.com/RJPhenom/SeinARTSFramework';
---

<nav class="nav-hidden">
  <div class="inner">
    <a href="#" class="wordmark" aria-label="SeinARTS Framework Home">
      <img src="/branding/SeinARTSWordmarkVectorized.svg" alt="SeinARTS Framework" />
    </a>
    <button
      class="menu-toggle"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="links" id="nav-links" role="list">
      <li><a href="/#features">Features</a></li>
      <li><a href="/#changelog">Changelog</a></li>
      <li>
        <a href={DOCS_URL} target="_blank" rel="noopener noreferrer" class="link-docs">
          Docs
        </a>
      </li>
      <li>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="link-github">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10Z"/>
          </svg>
          GitHub
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    min-height: var(--nav-h);
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateY(-100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  nav.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark img {
    display: block;
    height: 40px;
    width: auto;
    margin: 0;
    position: static;
    transition: opacity 0.2s;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
  }

  .wordmark:hover img {
    opacity: 0.7;
  }

  .links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }

  .menu-toggle {
    display: none;
    width: 2.5rem;
    height: 2.5rem;
    border: none;
    background: rgba(255, 255, 255, 0.01);
    color: var(--white);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.26rem;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 1rem;
    height: 2px;
    background: currentColor;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    border: 1px solid transparent;
    background: transparent;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .links a:hover {
    color: var(--white);
    border-color: var(--blue);
    background: rgba(0, 149, 255, 0.07);
  }

  .link-docs {
    color: var(--text-muted) !important;
  }

  .link-docs:hover {
    color: var(--white) !important;
    opacity: 1;
  }

  .link-github {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.4rem 1rem;
    border: 1px solid #3d3d3d;
    border-radius: 0;
    color: var(--white) !important;
    font-size: 0.875rem !important;
    background: rgba(255, 255, 255, 0.01);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition: border-color 0.2s, background 0.2s, color 0.2s !important;
  }

  .link-github:hover {
    border-color: var(--red) !important;
    background: rgba(255, 0, 0, 0.08) !important;
    color: var(--white) !important;
  }

  @media (max-width: 600px) {
    .menu-toggle {
      display: inline-flex;
    }

    .inner {
      position: relative;
      padding: 0.25rem 1rem;
    }

    .wordmark {
      margin-left: 1rem;
    }

    .links {
      position: absolute;
      top: calc(100% + 0.35rem);
      right: 1rem;
      min-width: 11rem;
      padding: 0.5rem;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      border: 1px solid var(--border);
      background: rgba(0, 0, 0, 0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      opacity: 0;
      transform: translateY(-8px);
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
      z-index: 110;
    }

    nav.menu-open .links {
      opacity: 1;
      transform: translateY(0);
      visibility: visible;
      pointer-events: auto;
    }

    .links a,
    .link-github {
      width: 100%;
      justify-content: flex-start;
    }

    nav.menu-open .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    nav.menu-open .menu-toggle span:nth-child(2) {
      opacity: 0;
    }

    nav.menu-open .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
  }
</style>

<script>
  const nav = document.querySelector('nav');
  const wordmark = document.querySelector('.wordmark');
  const menuToggle = document.querySelector('.menu-toggle');
  const navLinks = document.querySelector('.links');

  function closeMenu() {
    nav?.classList.remove('menu-open');
    menuToggle?.setAttribute('aria-expanded', 'false');
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('menu-open') ?? false;
    menuToggle?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  navLinks?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 600) {
        closeMenu();
      }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 600) {
      closeMenu();
    }
  });

  function onScroll() {
    if (window.scrollY >= 250) {
      nav?.classList.add('visible');
    } else {
      nav?.classList.remove('visible');
    }
  }

  wordmark?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (window.innerWidth <= 600) {
      closeMenu();
    }
  });

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
