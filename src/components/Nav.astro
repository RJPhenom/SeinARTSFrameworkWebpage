---
const DOCS_URL = 'https://docs.seinarts.gg';
const GITHUB_URL = 'https://github.com/RJPhenom/SeinARTSFramework';
---

<nav class="nav-hidden">
  <div class="inner">
    <a href="#" class="wordmark" aria-label="SeinARTS Framework Home">
      <img src="/branding/SeinARTSWordmark.svg" alt="SeinARTS Framework" />
    </a>
    <ul class="links" role="list">
      <li><a href="/#features">Features</a></li>
      <li><a href="/#changelog">Changelog</a></li>
      <li>
        <a href={DOCS_URL} target="_blank" rel="noopener noreferrer" class="link-docs">
          Docs
        </a>
      </li>
      <li>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="link-github">
          GitHub
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    min-height: var(--nav-h);
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateY(-100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  nav.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.5rem 2rem;
    min-height: calc(var(--nav-h) + 2rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark img {
    display: block;
    height: 32px;
    width: auto;
    margin: 0;
    position: static;
    transition: opacity 0.2s;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    margin: 1rem 0;
    cursor: pointer;
  }

  .wordmark:hover img {
    opacity: 0.7;
  }

  .links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    border: 1px solid transparent;
    background: transparent;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .links a:hover {
    color: var(--white);
    border-color: var(--blue);
    background: rgba(0, 149, 255, 0.07);
  }

  .link-docs {
    color: var(--text-muted) !important;
  }

  .link-docs:hover {
    color: var(--white) !important;
    opacity: 1;
  }

  .link-github {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border: 1px solid #3d3d3d;
    border-radius: 0;
    color: var(--white) !important;
    font-size: 0.875rem !important;
    background: rgba(255, 255, 255, 0.01);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition: border-color 0.2s, background 0.2s, color 0.2s !important;
  }

  .link-github:hover {
    border-color: var(--red) !important;
    background: rgba(255, 0, 0, 0.08) !important;
    color: var(--white) !important;
  }

  @media (max-width: 600px) {
    .links li:not(:last-child):not(:nth-last-child(2)) {
      display: none;
    }
  }
</style>

<script>
  const nav = document.querySelector('nav');
  const wordmark = document.querySelector('.wordmark');

  function onScroll() {
    if (window.scrollY >= 250) {
      nav?.classList.add('visible');
    } else {
      nav?.classList.remove('visible');
    }
  }

  wordmark?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
