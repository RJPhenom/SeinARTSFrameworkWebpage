---
const DOCS_URL = 'https://docs.seinarts.gg';
const GITHUB_URL = 'https://github.com/RJPhenom/SeinARTSFramework';
---

<section class="hero">
  <canvas class="bg-grid" aria-hidden="true"></canvas>
  <div class="bg-glow" aria-hidden="true"></div>

  <div class="content">
    <div class="wordmark-wrap">
      <img
        src="/branding/SeinARTSWordmarkVectorized.svg?v=20260415b"
        alt="SeinARTS Framework"
        class="wordmark"
        height="38"
      />
    </div>

    <p class="tagline">
      A deterministic lockstep RTS framework<br />for Unreal Engine&nbsp;5.
    </p>

    <div class="ctas">
      <a href={DOCS_URL} target="_blank" rel="noopener noreferrer" class="btn btn-docs">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M4 6h16M4 10h16M4 14h10M4 18h7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
        Docs
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="btn btn-github">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10Z"/>
        </svg>
        GitHub
      </a>
    </div>

    <p class="meta-badge">Unreal Engine 5 &nbsp;·&nbsp; Open Source</p>

    <a href="/#features" class="scroll-next" aria-label="Scroll to Features section">
      <span aria-hidden="true" class="scroll-next-arrow">↓</span>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: calc(var(--nav-h) + 2rem) 2rem 3.5rem;
  }

  /* Dot grid background */
  .bg-grid {
    position: absolute;
    inset: 0;
    opacity: 0.9;
    width: 100%;
    height: 100%;
    pointer-events: none;
    mask-image: radial-gradient(
      ellipse 85% 85% at 50% 50%,
      black 30%,
      transparent 100%
    );
  }

  /* Ambient color wash */
  .bg-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 62% 58% at 108% 0%,
        rgba(255, 0, 0, 0.095) 0%,
        rgba(0, 149, 255, 0.078) 40%,
        transparent 80%
      ),
      radial-gradient(
        ellipse 62% 58% at -8% 100%,
        rgba(0, 149, 255, 0.085) 0%,
        rgba(255, 0, 0, 0.06) 40%,
        transparent 80%
      );
    pointer-events: none;
  }

  .bg-glow::before,
  .bg-glow::after {
    content: '';
    position: absolute;
    top: -12%;
    bottom: -12%;
    width: 38%;
    opacity: 0.82;
    filter: blur(18px);
    will-change: transform, opacity;
  }

  .bg-glow::before {
    left: -8%;
    background: radial-gradient(
      ellipse 72% 54% at 0% 50%,
      rgba(0, 149, 255, 0.18) 0%,
      rgba(255, 0, 0, 0.12) 42%,
      transparent 78%
    );
    animation: glowBloomLeft 6s ease-in-out infinite;
  }

  .bg-glow::after {
    right: -14%;
    background: radial-gradient(
      ellipse 78% 58% at 108% 50%,
      rgba(255, 0, 0, 0.18) 0%,
      rgba(0, 149, 255, 0.125) 44%,
      transparent 84%
    );
    animation: glowBloomRight 6s ease-in-out infinite;
  }

  @keyframes glowBloomLeft {
    0%,
    100% {
      opacity: 0.88;
      transform: translateY(8%) scale(1);
    }
    50% {
      opacity: 0.58;
      transform: translateY(-8%) scale(1.18, 1.12);
    }
  }

  @keyframes glowBloomRight {
    0%,
    100% {
      opacity: 0.88;
      transform: translateY(-8%) scale(1);
    }
    50% {
      opacity: 0.58;
      transform: translateY(8%) scale(1.18, 1.12);
    }
  }

  .content {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 620px;
  }

  .logo-wrap {
    margin-bottom: 0.25rem;
  }

  .logo {
    width: 96px;
    height: 96px;
    object-fit: contain;
    animation: float 7s ease-in-out infinite;
    filter: drop-shadow(0 0 24px rgba(255, 0, 0, 0.25))
      drop-shadow(0 0 48px rgba(0, 149, 255, 0.15));
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .wordmark-wrap {
    line-height: 1;
  }

  .wordmark {
    height: 102px;
    width: auto;
    display: block;
  }

  .tagline {
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.75;
    max-width: 440px;
  }

  .ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.25rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-width: 124px;
    padding: 0.7rem 1.6rem;
    border-radius: 0;
    border: 1px solid transparent;
    background: transparent;
    color: var(--white);
    font-size: 0.93rem;
    font-weight: 600;
    font-family: inherit;
    letter-spacing: 0;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s;
  }

  .btn svg {
    width: 17px;
    height: 17px;
  }

  .btn-docs {
    border-color: var(--red);
  }

  .btn-docs:hover {
    background: rgba(255, 0, 0, 0.08);
  }

  .btn-github {
    border-color: var(--blue);
  }

  .btn-github:hover {
    background: rgba(0, 149, 255, 0.08);
  }

  .meta-badge {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.22);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 0.25rem;
  }

  .scroll-next {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    background: transparent;
    color: var(--red);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    animation: arrowColor 3s ease-in-out infinite;
    flex-shrink: 0;
  }

  .scroll-next:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .scroll-next-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: 1.5rem;
    line-height: 1;
  }

  @keyframes arrowColor {
    0%,
    100% {
      color: var(--red);
    }
    50% {
      color: var(--blue);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-glow {
      opacity: 0.78;
    }

    .bg-glow::before,
    .bg-glow::after {
      animation: none;
      transform: none;
      opacity: 0.72;
    }

    .scroll-next {
      transition: background 0.2s ease;
      animation: none;
      color: var(--red);
    }

    .scroll-next-arrow {
      color: currentColor;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: calc(var(--nav-h) + 1.25rem) 1.25rem 2.25rem;
    }
  }

</style>

<script>
  const hero = document.querySelector<HTMLElement>('.hero');
  const gridCanvas = document.querySelector<HTMLCanvasElement>('.bg-grid');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (hero && gridCanvas) {
    const heroEl = hero;
    const canvasEl = gridCanvas;
    const context = canvasEl.getContext('2d');

    if (context) {
      const ctx = context;
      const spacing = 36;
      const baseRadius = 1;
      const influenceRadius = 180;
      const pullStrength = 16;
      const driftPixelsPerMs = (36 * 3) / 26000;
      const maxDpr = 2;
      const pointer = {
        x: 0,
        y: 0,
        active: false,
      };

      let width = 0;
      let height = 0;
      let devicePixelRatioValue = 1;
      let animationFrameId = 0;
      let dots: Array<{ x: number; y: number }> = [];

      function rebuildDots() {
        dots = [];

        for (let y = -spacing; y <= height + spacing; y += spacing) {
          for (let x = -spacing; x <= width + spacing; x += spacing) {
            dots.push({ x, y });
          }
        }
    }

      function resizeCanvas() {
        const bounds = heroEl.getBoundingClientRect();

        width = bounds.width;
        height = bounds.height;
        devicePixelRatioValue = Math.min(window.devicePixelRatio || 1, maxDpr);

        canvasEl.width = Math.round(width * devicePixelRatioValue);
        canvasEl.height = Math.round(height * devicePixelRatioValue);
        ctx.setTransform(devicePixelRatioValue, 0, 0, devicePixelRatioValue, 0, 0);

        rebuildDots();
      }

      function updatePointer(event: PointerEvent) {
        const bounds = heroEl.getBoundingClientRect();
        pointer.x = event.clientX - bounds.left;
        pointer.y = event.clientY - bounds.top;
        pointer.active = true;
      }

      function resetPointer() {
        pointer.active = false;
      }

      function drawFrame(timestamp: number) {
        ctx.clearRect(0, 0, width, height);

        const pulse = reduceMotion.matches ? 1 : 0.92 + Math.sin(timestamp * 0.0011) * 0.08;
        const driftOffset = reduceMotion.matches ? 0 : (timestamp * driftPixelsPerMs) % spacing;

        for (const dot of dots) {
          let drawX = dot.x + driftOffset;
          let drawY = dot.y + driftOffset;
          let dotRadius = baseRadius;
          let alpha = 0.19 * pulse;

          if (pointer.active && !reduceMotion.matches) {
            const deltaX = pointer.x - dot.x;
            const deltaY = pointer.y - dot.y;
            const distance = Math.hypot(deltaX, deltaY);

            if (distance < influenceRadius && distance > 0.001) {
              const falloff = 1 - distance / influenceRadius;
              const force = falloff * falloff;

              drawX += (deltaX / distance) * pullStrength * force;
              drawY += (deltaY / distance) * pullStrength * force;
              dotRadius += force * 0.65;
              alpha += force * 0.22;
            }
          }

          ctx.beginPath();
          ctx.arc(drawX, drawY, dotRadius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${Math.min(alpha, 0.42)})`;
          ctx.fill();
        }

        animationFrameId = window.requestAnimationFrame(drawFrame);
      }

      resizeCanvas();
      animationFrameId = window.requestAnimationFrame(drawFrame);

      if (!reduceMotion.matches) {
        heroEl.addEventListener('pointermove', updatePointer, { passive: true });
        heroEl.addEventListener('pointerleave', resetPointer, { passive: true });
      }

      window.addEventListener('resize', resizeCanvas);
      reduceMotion.addEventListener('change', resetPointer);
      window.addEventListener('pagehide', () => window.cancelAnimationFrame(animationFrameId), {
        once: true,
      });
    }
  }
</script>
