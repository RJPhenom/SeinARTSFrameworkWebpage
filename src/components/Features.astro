---
const features = [
  {
    title: 'Deterministic Simulation',
    description:
      'Guaranteed identical game state across every client, every tick. No divergence. No desyncs.',
    accent: 'red',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 2L18 10L10 18L2 10L10 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="10" cy="10" r="2.5" fill="currentColor"/></svg>`,
  },
  {
    title: 'Lockstep Networking',
    description:
      'Ultra-low bandwidth synchronisation purpose-built for real-time strategy at any player count.',
    accent: 'blue',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 10H17M17 10L13 6M17 10L13 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 10H3M3 10L7 6M3 10L7 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"/></svg>`,
  },
  {
    title: 'Unreal Engine 5 Native',
    description:
      'Deep UE5 integration with first-class Blueprint support and full C++ access throughout.',
    accent: 'red',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 10L9.5 12.5L13 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Modular Architecture',
    description:
      'Use only what your game needs. Every system is independently configurable and composable.',
    accent: 'blue',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="2" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="11" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    title: 'Command Framework',
    description:
      'A flexible, extensible input and command abstraction system designed from the ground up for RTS.',
    accent: 'red',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7 4L16 10L7 16V4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Replay Support',
    description:
      'Full deterministic replay system out of the box. Record, store, and play back any match precisely.',
    accent: 'blue',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 10C4 6.686 6.686 4 10 4a6 6 0 0 1 5.196 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M15.196 7V3.5H18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/><path d="M16 10c0 3.314-2.686 6-6 6s-6-2.686-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];
---

<section class="features" id="features">
  <div class="inner">
    <div class="section-header">
      <span class="label">Capabilities</span>
      <h2>Built for serious RTS development</h2>
      <p class="subtitle">
        Everything you need to build a competitive real-time strategy game on Unreal Engine 5.
      </p>
    </div>

    <div class="grid">
      {
        features.map((f) => (
          <div class={`card accent-${f.accent}`}>
            <div class={`card-icon accent-${f.accent}`} set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding: 6rem 2rem;
    border-top: 1px solid var(--border);
  }

  .inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 1rem;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .subtitle {
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .card {
    background: var(--surface);
    padding: 2rem;
    position: relative;
    transition: background 0.2s;
  }

  .card:hover {
    background: var(--surface-2);
  }

  /* Accent top-border on hover */
  .card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover::after {
    opacity: 1;
  }

  .card.accent-red::after {
    background: var(--red);
  }

  .card.accent-blue::after {
    background: var(--blue);
  }

  .card-icon {
    display: flex;
    margin-bottom: 1.1rem;
    line-height: 1;
  }

  .card-icon.accent-red {
    color: var(--red);
  }

  .card-icon.accent-blue {
    color: var(--blue);
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }
</style>
