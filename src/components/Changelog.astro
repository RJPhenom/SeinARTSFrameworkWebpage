---
const RELEASES_URL = 'https://github.com/RJPhenom/SeinARTSFramework/releases';

// Add future releases to the top of this array.
const releases = [
  {
    version: '0.1.0',
    date: '2026-04-01',
    tag: 'Initial Release',
    notes: [
      'Core deterministic simulation loop',
      'Lockstep networking foundation',
      'Command input abstraction system',
      'Basic Unreal Engine 5 integration layer',
    ],
  },
];

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section class="changelog" id="changelog">
  <div class="inner">
    <div class="section-header">
      <span class="label">Changelog</span>
      <h2>Latest Releases</h2>
    </div>

    <div class="releases">
      {
        releases.map((r) => (
          <div class="release">
            <div class="release-meta">
              <span class="version">v{r.version}</span>
              <span class="release-tag">{r.tag}</span>
              <time class="date" datetime={r.date}>{formatDate(r.date)}</time>
            </div>
            <ul class="notes" role="list">
              {r.notes.map((note) => (
                <li>
                  <span class="bullet" aria-hidden="true" />
                  {note}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="view-all">
      <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer" class="view-all-link">
        View all releases on GitHub →
      </a>
    </div>
  </div>
</section>

<style>
  .changelog {
    padding: 6rem 2rem;
    border-top: 1px solid var(--border);
  }

  .inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 1rem;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .releases {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .release {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 2rem;
  }

  .release-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .version {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--white);
  }

  .release-tag {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--red);
    background: rgba(255, 0, 0, 0.09);
    border: 1px solid rgba(255, 0, 0, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .date {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-left: auto;
  }

  .notes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .notes li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .bullet {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--blue);
    margin-top: 0.55em;
  }

  .view-all {
    text-align: center;
    margin-top: 2rem;
  }

  .view-all-link {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .view-all-link:hover {
    color: var(--white);
  }
</style>
